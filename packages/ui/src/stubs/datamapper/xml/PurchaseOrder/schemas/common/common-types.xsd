  <!-- ================================================================ -->
  <!-- ATTRIBUTE GROUPS -->
  <!-- ================================================================ -->

  <xs:attributeGroup name="CommonAttributes">
    <xs:annotation>
      <xs:documentation>
        Common attributes used across multiple elements.
        Provides ID, version, and timestamp tracking.
      </xs:documentation>
    </xs:annotation>
    <xs:attribute name="id" type="ct:UUID_t" use="optional">
      <xs:annotation>
        <xs:documentation>Unique identifier for the element.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="version" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>Version number of the element.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="timestamp" type="xs:dateTime" use="optional">
      <xs:annotation>
        <xs:documentation>Timestamp when element was created/modified.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:attributeGroup>

  <xs:attributeGroup name="AuditAttributes">
    <xs:annotation>
      <xs:documentation>
        Audit trail attributes for tracking changes.
      </xs:documentation>
    </xs:annotation>
    <xs:attribute name="createdBy" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>User who created the element.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="createdDate" type="xs:dateTime" use="optional">
      <xs:annotation>
        <xs:documentation>Date/time when element was created.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="modifiedBy" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>User who last modified the element.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="modifiedDate" type="xs:dateTime" use="optional">
      <xs:annotation>
        <xs:documentation>Date/time when element was last modified.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:attributeGroup>

  <xs:attributeGroup name="StatusAttributes">
    <xs:annotation>
      <xs:documentation>
        Status tracking attributes.
      </xs:documentation>
    </xs:annotation>
    <xs:attribute name="status" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>Current status of the element.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="statusDate" type="xs:dateTime" use="optional">
      <xs:annotation>
        <xs:documentation>Date/time when status was set.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
    <xs:attribute name="statusReason" type="xs:string" use="optional">
      <xs:annotation>
        <xs:documentation>Reason for current status.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:attributeGroup>

  <!-- ================================================================ -->
  <!-- COMPLEX TYPES FOR COMMON STRUCTURES -->
  <!-- ================================================================ -->

  <xs:complexType name="Note_t">
    <xs:annotation>
      <xs:documentation>
        Generic note/comment structure.
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="type" type="xs:string" use="optional"/>
        <xs:attribute name="author" type="xs:string" use="optional"/>
        <xs:attribute name="date" type="xs:dateTime" use="optional"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="Attachment_t">
    <xs:annotation>
      <xs:documentation>
        File attachment reference structure.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="FileName" type="xs:string"/>
      <xs:element name="FileType" type="xs:string"/>
      <xs:element name="FileSize" type="xs:long" minOccurs="0"/>
      <xs:element name="FileURL" type="ct:URL_t" minOccurs="0"/>
      <xs:element name="Description" type="xs:string" minOccurs="0"/>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
  </xs:complexType>

</xs:schema>
