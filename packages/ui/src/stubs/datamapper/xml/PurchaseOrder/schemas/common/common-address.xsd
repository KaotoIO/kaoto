<?xml version="1.0" encoding="UTF-8"?>
<!--
  Common Address Schema
  
  Purpose: Shared address types and structures with substitution groups
  Demonstrates: Substitution groups, abstract elements, xs:restriction patterns
  
  This schema provides address type definitions used across all main schemas.
  Follows enterprise patterns similar to FIXML/FPML/FMM for address handling.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:addr="http://www.kaoto.io/common/address"
           xmlns:ct="http://www.kaoto.io/common/types"
           targetNamespace="http://www.kaoto.io/common/address"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <!-- Import common types for postal codes, country codes, etc. -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common-types.xsd"/>

  <!-- ================================================================ -->
  <!-- DOCUMENTATION -->
  <!-- ================================================================ -->
  <xs:annotation>
    <xs:documentation xml:lang="en">
      Common Address Schema for Kaoto DataMapper Enterprise Testing
      
      This schema provides address type definitions including:
      - Abstract address base with substitution group
      - Domestic address types (US, Canada, etc.)
      - International address types
      - Special address types (PO Box, Military, etc.)
      - Address validation patterns
      
      Version: 1.0
      Namespace: http://www.kaoto.io/common/address
    </xs:documentation>
  </xs:annotation>

  <!-- ================================================================ -->
  <!-- ADDRESS SUBSTITUTION GROUP BASE -->
  <!-- ================================================================ -->

  <xs:element name="Address" type="addr:Abstract_Address_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base element for address substitution group.
        All concrete address types substitute this element.
        Demonstrates: Substitution group pattern as used in FIXML/FPML.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================ -->
  <!-- ABSTRACT ADDRESS BASE TYPE -->
  <!-- ================================================================ -->

  <xs:complexType name="Abstract_Address_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base type for all address types.
        Provides common address fields that all concrete types extend.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AddressID" type="ct:ID_t">
        <xs:annotation>
          <xs:documentation>Unique identifier for this address.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AddressLine1" type="xs:string">
        <xs:annotation>
          <xs:documentation>Primary address line (street address).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AddressLine2" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Secondary address line (apartment, suite, etc.).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AddressLine3" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Additional address line if needed.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="City" type="xs:string">
        <xs:annotation>
          <xs:documentation>City or locality name.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Country" type="ct:CountryCode_t">
        <xs:annotation>
          <xs:documentation>ISO 3166-1 alpha-2 country code.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attribute name="addressType" type="addr:AddressType_t" use="optional">
      <xs:annotation>
        <xs:documentation>Type classification of the address.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- STANDARD ADDRESS (Most Common) -->
  <!-- ================================================================ -->

  <xs:element name="StandardAddress" substitutionGroup="addr:Address" type="addr:StandardAddress_t">
    <xs:annotation>
      <xs:documentation>
        Standard address with flexible state/province and postal code.
        Most commonly used address type.
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="StandardAddress_t">
    <xs:annotation>
      <xs:documentation>
        Standard address type with flexible fields for international use.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="StateProvince" type="xs:string">
            <xs:annotation>
              <xs:documentation>State, province, or region.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PostalCode" type="xs:string">
            <xs:annotation>
              <xs:documentation>Postal/ZIP code.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- US DOMESTIC ADDRESS -->
  <!-- ================================================================ -->

  <xs:element name="DomesticAddress_US" substitutionGroup="addr:Address" type="addr:DomesticAddress_US_t">
    <xs:annotation>
      <xs:documentation>
        US domestic address with state and ZIP code.
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="DomesticAddress_US_t">
    <xs:annotation>
      <xs:documentation>
        US domestic address type extending abstract address base.
        Demonstrates: xs:extension pattern.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="State" type="addr:USState_t">
            <xs:annotation>
              <xs:documentation>US state code (2-letter abbreviation).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PostalCode" type="ct:PostalCode_US_t">
            <xs:annotation>
              <xs:documentation>US ZIP code (5-digit or ZIP+4 format).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="County" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>County name (optional).</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- CANADIAN DOMESTIC ADDRESS -->
  <!-- ================================================================ -->

  <xs:element name="DomesticAddress_CA" substitutionGroup="addr:Address" type="addr:DomesticAddress_CA_t">
    <xs:annotation>
      <xs:documentation>
        Canadian domestic address with province and postal code.
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="DomesticAddress_CA_t">
    <xs:annotation>
      <xs:documentation>
        Canadian domestic address type extending abstract address base.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="Province" type="addr:CanadianProvince_t">
            <xs:annotation>
              <xs:documentation>Canadian province/territory code.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PostalCode" type="ct:PostalCode_CA_t">
            <xs:annotation>
              <xs:documentation>Canadian postal code (A1A 1A1 format).</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- UK DOMESTIC ADDRESS -->
  <!-- ================================================================ -->

  <xs:element name="DomesticAddress_UK" substitutionGroup="addr:Address" type="addr:DomesticAddress_UK_t">
    <xs:annotation>
      <xs:documentation>
        UK domestic address with postcode.
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="DomesticAddress_UK_t">
    <xs:annotation>
      <xs:documentation>
        UK domestic address type extending abstract address base.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="PostalCode" type="ct:PostalCode_UK_t">
            <xs:annotation>
              <xs:documentation>UK postcode (e.g., SW1A 1AA).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="County" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>County name (optional).</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- INTERNATIONAL ADDRESS -->
  <!-- ================================================================ -->

  <xs:element name="InternationalAddress" substitutionGroup="addr:Address" type="addr:InternationalAddress_t">
    <xs:annotation>
      <xs:documentation>
        Generic international address for countries without specific format.
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="InternationalAddress_t">
    <xs:annotation>
      <xs:documentation>
        International address type with flexible state/province and postal code.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="StateProvince" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>State, province, or region name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PostalCode" type="ct:PostalCode_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Postal/ZIP code in local format.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Region" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Additional regional identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- PO BOX ADDRESS -->
  <!-- ================================================================ -->

  <xs:element name="POBoxAddress" substitutionGroup="addr:Address" type="addr:POBoxAddress_t">
    <xs:annotation>
      <xs:documentation>
        Post Office Box address.
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="POBoxAddress_t">
    <xs:annotation>
      <xs:documentation>
        PO Box address type with box number and postal facility.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="POBoxNumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Post Office Box number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StateProvince" type="xs:string">
            <xs:annotation>
              <xs:documentation>State or province.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PostalCode" type="xs:string">
            <xs:annotation>
              <xs:documentation>Postal code for the PO Box facility.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- MILITARY ADDRESS (APO/FPO/DPO) -->
  <!-- ================================================================ -->

  <xs:element name="MilitaryAddress" substitutionGroup="addr:Address" type="addr:MilitaryAddress_t">
    <xs:annotation>
      <xs:documentation>
        US Military address (APO/FPO/DPO).
        Substitutes Address element in substitution group.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="MilitaryAddress_t">
    <xs:annotation>
      <xs:documentation>
        Military address type for APO/FPO/DPO addresses.
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="addr:Abstract_Address_t">
        <xs:sequence>
          <xs:element name="MilitaryPostOffice" type="addr:MilitaryPostOfficeType_t">
            <xs:annotation>
              <xs:documentation>Type of military post office (APO/FPO/DPO).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MilitaryState" type="addr:MilitaryState_t">
            <xs:annotation>
              <xs:documentation>Military state code (AE/AP/AA).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PostalCode" type="ct:PostalCode_US_t">
            <xs:annotation>
              <xs:documentation>ZIP code for military address.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ENUMERATIONS -->
  <!-- ================================================================ -->

  <xs:simpleType name="AddressType_t">
    <xs:annotation>
      <xs:documentation>Address type classification.</xs:documentation>
    </xs:annotation>
    <xs:restriction base="xs:string">
      <xs:enumeration value="Residential"><xs:annotation><xs:documentation>Residential address</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="Commercial"><xs:annotation><xs:documentation>Commercial/business address</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="Industrial"><xs:annotation><xs:documentation>Industrial facility address</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="Government"><xs:annotation><xs:documentation>Government facility address</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="Military"><xs:annotation><xs:documentation>Military facility address</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="POBox"><xs:annotation><xs:documentation>Post Office Box</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="Warehouse"><xs:annotation><xs:documentation>Warehouse/distribution center</xs:documentation></xs:annotation></xs:enumeration>
      <xs:enumeration value="RetailStore"><xs:annotation><xs:documentation>Retail store location</xs:documentation></xs:annotation></xs:enumeration>
    </xs:restriction>
  </xs:simpleType>

