<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:so="http://www.kaoto.io/shiporder"
           xmlns:ct="http://www.kaoto.io/common/types"
           xmlns:ca="http://www.kaoto.io/common/address"
           xmlns:cp="http://www.kaoto.io/common/party"
           targetNamespace="http://www.kaoto.io/shiporder"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <xs:annotation>
    <xs:documentation>
      Ship Order Core Module
      
      This module contains the core shipment types and structures that form
      the foundation of the ShipOrder schema. These are the fundamental
      building blocks used throughout the schema.
      
      Module Contents:
      - Order identification types
      - Order metadata and audit types
      - Customer information types
      - Shipment details and line items
      - Product information types
      - Contact and notification types
      - Supporting complex types
      
      Usage:
      This module is included in the main ShipOrder.xsd via xs:include.
      All types defined here are in the ShipOrder namespace.
      
      Design Philosophy:
      Core types are designed to be reusable and extensible. They provide
      the common structure that all shipment types build upon, following
      the principle of composition over inheritance where appropriate.
      
      Version: 1.0
      Part of: ShipOrder Schema Modularization
    </xs:documentation>
  </xs:annotation>

  <!-- Import common types -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common/common-types.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/address"
             schemaLocation="common/common-address.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/party"
             schemaLocation="common/common-party.xsd"/>

  <!-- ================================================================ -->
  <!-- ORDER IDENTIFICATION TYPES                                       -->
  <!-- ================================================================ -->

  <xs:complexType name="OrderIdentificationType">
    <xs:annotation>
      <xs:documentation>
        Comprehensive identification for shipping orders.
        
        Provides multiple identifiers to link this shipping order to
        source systems, purchase orders, and customer accounts.
        Supports traceability and integration across systems.
        
        Key Elements:
        - ShipOrderID: Unique identifier for this shipping order
        - PurchaseOrderReference: Link to source purchase order
        - CustomerOrderNumber: Customer's own reference number
        - ExternalReferences: Links to external systems (ERP, CRM, etc.)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ShipOrderID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>
            Unique identifier for this shipping order.
            Generated by the shipping system, globally unique (UUID format).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PurchaseOrderReference" type="so:OrderReferenceType">
        <xs:annotation>
          <xs:documentation>
            Reference to the source purchase order.
            Links this shipment back to the original customer order.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomerOrderNumber" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Customer's own order number or reference.
            Optional - used when customer provides their own tracking number.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ExternalReferences" type="so:ExternalReferencesType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            References to external systems (ERP, CRM, WMS, etc.).
            Optional - used for enterprise system integration.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="OrderReferenceType">
    <xs:annotation>
      <xs:documentation>
        Reference to a related order document.
        
        Generic type for linking to purchase orders, invoices, quotes, etc.
        Provides both unique ID and human-readable reference number.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ReferenceID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>
            Unique identifier of the referenced document (UUID format).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ReferenceNumber" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Human-readable reference number.
            Example: "PO-2024-001234", "INV-2024-005678"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ReferenceDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>
            Date of the referenced document.
            Used for sorting and filtering references.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="referenceType" type="xs:string" use="required">
      <xs:annotation>
        <xs:documentation>
          Type of reference document.
          Examples: "PurchaseOrder", "Invoice", "Quote", "Contract"
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="ExternalReferencesType">
    <xs:annotation>
      <xs:documentation>
        Collection of references to external systems.
        
        Supports integration with ERP, WMS, TMS, and other enterprise systems.
        Each reference links this order to an external system's identifier.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ExternalReference" maxOccurs="unbounded">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="SystemName" type="xs:string">
              <xs:annotation>
                <xs:documentation>
                  Name of the external system.
                  Examples: "SAP", "Oracle ERP", "Manhattan WMS", "Salesforce"
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="ReferenceID" type="xs:string">
              <xs:annotation>
                <xs:documentation>
                  Identifier in the external system.
                  Format depends on the external system.
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="ReferenceType" type="xs:string" minOccurs="0">
              <xs:annotation>
                <xs:documentation>
                  Type of reference in the external system.
                  Examples: "SalesOrder", "WorkOrder", "ShipmentID"
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ORDER METADATA TYPES                                             -->
  <!-- ================================================================ -->

  <xs:complexType name="OrderMetadataType">
    <xs:annotation>
      <xs:documentation>
        Metadata about order creation and processing.
        
        Tracks system information, timestamps, and processing status.
        Essential for audit trails and system integration.
        
        Key Elements:
        - CreatedDateTime: When order was created
        - LastModifiedDateTime: When order was last updated
        - CreatedBy: User or system that created the order
        - ProcessingStatus: Current status in workflow
        - SourceSystem: Originating system
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="CreatedDateTime" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>
            Timestamp when this shipping order was created.
            ISO 8601 format with timezone.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LastModifiedDateTime" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>
            Timestamp of last modification to this order.
            Updated whenever order is changed.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CreatedBy" type="so:SystemUserType">
        <xs:annotation>
          <xs:documentation>
            User or system that created this order.
            Used for audit and authorization.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProcessingStatus" type="so:ProcessingStatusEnum">
        <xs:annotation>
          <xs:documentation>
            Current processing status of this order.
            Values: Draft, Submitted, Validated, Processing, OnHold, Cancelled, Completed
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SourceSystem" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            System that originated this shipping order.
            Examples: "OrderManagement", "XSLT Transform", "API Gateway"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="SystemUserType">
    <xs:annotation>
      <xs:documentation>
        Represents a user or system account.
        
        Used for audit trails, access control, and tracking who
        performed actions on the order.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="UserID" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Unique identifier for the user or system account.
            Format depends on authentication system.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UserName" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Display name for the user or system.
            Human-readable identifier.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UserType" type="so:UserTypeEnum">
        <xs:annotation>
          <xs:documentation>
            Type of user account.
            Values: Human, System, API, Batch, Integration
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- CUSTOMER INFORMATION TYPES                                       -->
  <!-- ================================================================ -->

  <xs:complexType name="CustomerInformationType">
    <xs:annotation>
      <xs:documentation>
        Complete customer information for shipping.
        
        Includes contact details, account references, and preferences.
        Central to coordinating delivery and customer communication.
        
        Key Elements:
        - CustomerID: Unique customer identifier
        - CustomerDetails: Full customer profile
        - ContactInformation: Delivery coordination contacts
        - CustomerPreferences: Shipping and notification preferences
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="CustomerID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>
            Unique identifier for the customer (UUID format).
            Links to customer master data.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomerDetails">
        <xs:annotation>
          <xs:documentation>
            Detailed customer information.
            Contains abstract cp:Party substitution group.
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element ref="cp:Party"/>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="ContactInformation" type="so:ContactInformationType">
        <xs:annotation>
          <xs:documentation>
            Primary contact information for delivery coordination.
            Phone, email, and preferred contact method.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomerPreferences" type="so:CustomerPreferencesType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Customer preferences for shipping and delivery.
            Optional - uses system defaults if not specified.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ContactInformationType">
    <xs:annotation>
      <xs:documentation>
        Contact information for delivery coordination.
        
        Includes phone numbers, email, and preferred contact method.
        Used by carrier to coordinate delivery.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="PrimaryPhone" type="ct:PhoneNumber_t">
        <xs:annotation>
          <xs:documentation>
            Primary phone number for delivery contact.
            Used for delivery notifications and coordination.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AlternatePhone" type="ct:PhoneNumber_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Alternate phone number if primary is unavailable.
            Optional backup contact number.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="EmailAddress" type="ct:EmailAddress_t">
        <xs:annotation>
          <xs:documentation>
            Email address for shipping notifications.
            Used for tracking updates and delivery confirmations.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PreferredContactMethod" type="so:ContactMethodEnum">
        <xs:annotation>
          <xs:documentation>
            Customer's preferred method for delivery contact.
            Values: Phone, Email, SMS, NoContact
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="CustomerPreferencesType">
    <xs:annotation>
      <xs:documentation>
        Customer preferences for shipping and delivery.
        
        Influences carrier selection, delivery options, and notifications.
        Helps provide personalized service.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="PreferredCarrier" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Customer's preferred shipping carrier.
            Examples: "UPS", "FedEx", "USPS", "DHL"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DeliveryInstructions" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Special delivery instructions from customer.
            Examples: "Leave at side door", "Ring doorbell twice"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LeaveAtDoor" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>
            Whether package can be left at door without signature.
            Default is false for security.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NotificationPreferences" type="so:NotificationPreferencesType">
        <xs:annotation>
          <xs:documentation>
            Preferences for shipping notifications and updates.
            Controls when and how customer receives updates.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="NotificationPreferencesType">
    <xs:annotation>
      <xs:documentation>
        Preferences for shipping notifications.
        
        Controls when and how customer receives updates about their shipment.
        Supports email, SMS, and event-based notifications.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="EmailNotifications" type="xs:boolean" default="true">
        <xs:annotation>
          <xs:documentation>
            Whether to send email notifications.
            Default is true.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SMSNotifications" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>
            Whether to send SMS text notifications.
            Default is false (opt-in).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NotifyOnShipment" type="xs:boolean" default="true">
        <xs:annotation>
          <xs:documentation>
            Notify when order ships.
            Includes tracking number and estimated delivery.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NotifyOnDelivery" type="xs:boolean" default="true">
        <xs:annotation>
          <xs:documentation>
            Notify when order is delivered.
            Includes delivery confirmation and signature (if applicable).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NotifyOnException" type="xs:boolean" default="true">
        <xs:annotation>
          <xs:documentation>
            Notify if delivery exception occurs.
            Examples: Delay, address issue, delivery attempt failed.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- SHIPMENT DETAILS TYPES                                           -->
  <!-- ================================================================ -->

  <xs:complexType name="ShipmentDetailsType">
    <xs:annotation>
      <xs:documentation>
        Detailed information about items being shipped.
        
        Includes line items, quantities, and total value.
        Core content of the shipping order.
        
        Key Elements:
        - ShipmentLineItems: Collection of items being shipped
        - TotalQuantity: Sum of all item quantities
        - TotalValue: Declared value of shipment contents
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ShipmentLineItems" type="so:ShipmentLineItemsType">
        <xs:annotation>
          <xs:documentation>
            Collection of line items in this shipment.
            At least one line item is required.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TotalQuantity" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>
            Total quantity of all items in shipment.
            Sum of quantities from all line items.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TotalValue" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>
            Total declared value of shipment contents.
            Used for insurance and customs purposes.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ShipmentLineItemsType">
    <xs:annotation>
      <xs:documentation>
        Collection of line items in a shipment.
        
        Each line item represents a product being shipped with its quantity.
        At least one line item is required for a valid shipment.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LineItem" type="so:ShipmentLineItemType" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Individual line item in the shipment.
            Minimum one, maximum unbounded.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ShipmentLineItemType">
    <xs:annotation>
      <xs:documentation>
        Individual line item in a shipment.
        
        Represents a specific product with quantity, pricing, and location.
        Links to product master data via SKU.
        
        Key Elements:
        - LineItemID: Unique identifier within shipment
        - ProductInformation: Product details (SKU, name, weight, etc.)
        - Quantity: Number of units being shipped
        - UnitPrice: Price per unit
        - LineTotal: Total value (quantity × unit price)
        - InventoryLocation: Warehouse location
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LineItemID" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Unique identifier for this line item within the shipment.
            Format: "LI-0001", "LI-0002", etc.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProductInformation" type="so:ProductInformationType">
        <xs:annotation>
          <xs:documentation>
            Detailed product information for this line item.
            Includes SKU, name, description, weight, dimensions.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Quantity" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>
            Quantity of this product being shipped.
            Must be at least 1.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UnitPrice" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>
            Price per unit for this product.
            Used for customs and insurance valuation.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LineTotal" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>
            Total value for this line item.
            Calculated as: quantity × unit price
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InventoryLocation" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Warehouse location where item is stored.
            Examples: "A-12-03", "Zone-B-Shelf-45"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="lineNumber" type="xs:positiveInteger" use="required">
      <xs:annotation>
        <xs:documentation>
          Sequential line number within the shipment.
          Used for ordering and reference.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- PRODUCT INFORMATION TYPES                                        -->
  <!-- ================================================================ -->

  <xs:complexType name="ProductInformationType">
    <xs:annotation>
      <xs:documentation>
        Detailed product information.
        
        Includes identification (SKU, UPC), description, and physical
        characteristics (weight, dimensions). Essential for shipping
        calculations and customs documentation.
        
        Key Elements:
        - SKU: Stock Keeping Unit (unique identifier)
        - ProductName: Human-readable name
        - ProductDescription: Detailed description
        - UPC: Universal Product Code (barcode)
        - Weight: Unit weight
        - Dimensions: Physical dimensions
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="SKU" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Stock Keeping Unit - unique product identifier.
            Used to link to product master data.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProductName" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Human-readable product name.
            Displayed on packing slips and invoices.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProductDescription" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Detailed product description.
            Optional - used for customs and documentation.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UPC" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Universal Product Code (barcode).
            Optional - used for scanning and inventory.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Weight" type="ct:Weight_t">
        <xs:annotation>
          <xs:documentation>
            Weight of a single unit of this product.
            Used for shipping cost calculation.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Dimensions" type="so:DimensionsType" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Physical dimensions of the product.
            Optional - used for packaging and shipping calculations.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DimensionsType">
    <xs:annotation>
      <xs:documentation>
        Physical dimensions of an item or package.
        
        Measured in specified unit (inches, centimeters, etc.).
        Used for packaging selection and shipping cost calculation.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Length" type="xs:decimal">
        <xs:annotation>
          <xs:documentation>
            Length dimension (longest side).
            Decimal value in specified unit.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Width" type="xs:decimal">
        <xs:annotation>
          <xs:documentation>
            Width dimension (middle side).
            Decimal value in specified unit.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Height" type="xs:decimal">
        <xs:annotation>
          <xs:documentation>
            Height dimension (shortest side).
            Decimal value in specified unit.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="unit" type="so:DimensionUnitEnum" use="required">
      <xs:annotation>
        <xs:documentation>
          Unit of measurement for dimensions.
          Values: Inches, Centimeters, Feet, Meters
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- PACKAGING INFORMATION TYPES                                      -->
  <!-- ================================================================ -->

  <xs:complexType name="PackagingInformationType">
    <xs:annotation>
      <xs:documentation>
        Information about how items are packaged for shipment.
        
        Includes package details, materials, and special packaging requirements.
        Essential for carrier integration and shipping cost calculation.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Packages" type="so:PackagesType">
        <xs:annotation>
          <xs:documentation>
            Collection of packages in this shipment.
            At least one package is required.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="so:ShippingContainer" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Container types used for this shipment.
            Can be PalletContainer, CrateContainer, BoxContainer, EnvelopeContainer, or CustomContainer.
            Multiple containers can be specified.
            Uses substitution group pattern - DataMapper will show as choice.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PackagingMaterials" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Description of packaging materials used.
            Example: "Standard corrugated cardboard box with bubble wrap"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SpecialPackaging" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>
            Whether special packaging is required.
            True for fragile, hazmat, or temperature-controlled items.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PackagesType">
    <xs:annotation>
      <xs:documentation>
        Collection of packages in a shipment.
        Each package has its own tracking and dimensions.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Package" type="so:PackageType" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Individual package in the shipment.
            Minimum one, maximum unbounded.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="PackageType">
    <xs:annotation>
      <xs:documentation>
        Individual package in a shipment.
        
        Contains package identification, type, dimensions, weight,
        and contents. Each package can be tracked independently.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="PackageID" type="xs:string">
        <xs:annotation>
          <xs:documentation>
            Unique identifier for this package.
            Format: "PKG-20240612-001"
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PackageType" type="so:PackageTypeEnum">
        <xs:annotation>
          <xs:documentation>
            Type of package.
            Values: Box, Envelope, Tube, Pallet, Crate, Bag, Custom
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Dimensions" type="so:DimensionsType">
        <xs:annotation>
          <xs:documentation>
            Physical dimensions of the package.
            Used for shipping cost calculation.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Weight" type="ct:Weight_t">
        <xs:annotation>
          <xs:documentation>
            Total weight of the package including contents.
            Used for shipping cost calculation.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PackageContents" type="so:PackageContentsType">
        <xs:annotation>
          <xs:documentation>
            List of items contained in this package.
            Links to line items in the shipment.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="packageNumber" type="xs:positiveInteger" use="required">
      <xs:annotation>
        <xs:documentation>
          Sequential package number within the shipment.
          Example: 1, 2, 3, etc.
        </xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="PackageContentsType">
    <xs:annotation>
      <xs:documentation>
        List of items contained in a package.
        Links package contents to shipment line items.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ContentItem" maxOccurs="unbounded">
        <xs:complexType>
          <xs:sequence>
            <xs:element name="LineItemReference" type="xs:string">
              <xs:annotation>
                <xs:documentation>
                  Reference to line item ID in shipment.
                  Links package contents to shipment line items.
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="Quantity" type="xs:positiveInteger">
              <xs:annotation>
                <xs:documentation>
                  Quantity of this line item in this package.
                  May be less than total line item quantity if split across packages.
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

</xs:schema>
