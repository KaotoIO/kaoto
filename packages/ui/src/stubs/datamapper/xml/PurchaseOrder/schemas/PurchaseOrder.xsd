<?xml version="1.0" encoding="UTF-8"?>
<!--
  Purchase Order Schema (Source Body)
  
  Purpose: Main source schema for purchase order data with enterprise complexity
  Demonstrates: Substitution groups (4-5 levels), abstract elements in choice,
                xs:extension, xs:restriction, xs:import, xs:include patterns
  
  This schema represents a complex purchase order with multiple levels of
  substitution groups, abstract types, and nested choice constructs.
  Follows enterprise patterns similar to FIXML/FPML/FMM.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:po="http://www.kaoto.io/purchaseorder"
           xmlns:ct="http://www.kaoto.io/common/types"
           xmlns:addr="http://www.kaoto.io/common/address"
           xmlns:party="http://www.kaoto.io/common/party"
           xmlns:fin="http://www.kaoto.io/common/financial"
           xmlns:dt="http://www.kaoto.io/common/datetime"
           targetNamespace="http://www.kaoto.io/purchaseorder"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <!-- ================================================================ -->
  <!-- IMPORTS - Cross-namespace references -->
  <!-- ================================================================ -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common/common-types.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/address"
             schemaLocation="common/common-address.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/party"
             schemaLocation="common/common-party.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/financial"
             schemaLocation="common/common-financial.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/datetime"
             schemaLocation="common/common-datetime.xsd"/>

  <!-- ================================================================ -->
  <!-- DOCUMENTATION -->
  <!-- ================================================================ -->
  <xs:annotation>
    <xs:documentation xml:lang="en">
      Purchase Order Schema for Kaoto DataMapper Enterprise Testing
      
      This schema demonstrates enterprise-level complexity including:
      - 4-5 level substitution groups for order types
      - Abstract elements within xs:choice constructs
      - xs:extension and xs:restriction patterns
      - Complex nested structures
      - Integration with common schemas via xs:import
      
      Version: 1.0
      Namespace: http://www.kaoto.io/purchaseorder
      
      Total complexity: ~2000 lines
      Demonstrates: All advanced XSD features in combination
    </xs:documentation>
  </xs:annotation>

  <!-- ================================================================ -->
  <!-- ROOT ELEMENT -->
  <!-- ================================================================ -->

  <xs:element name="PurchaseOrder" type="po:PurchaseOrder_t">
    <xs:annotation>
      <xs:documentation>
        Root element for purchase order document.
        Represents a complete purchase order with all details.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================ -->
  <!-- PURCHASE ORDER TYPE -->
  <!-- ================================================================ -->

  <xs:complexType name="PurchaseOrder_t">
    <xs:annotation>
      <xs:documentation>
        Main purchase order structure.
        Contains header, items, pricing, and fulfillment details.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="OrderHeader" type="po:OrderHeader_t">
        <xs:annotation>
          <xs:documentation>Order header with identification and metadata.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="po:OrderType">
        <xs:annotation>
          <xs:documentation>
            Order type using substitution group (4 levels deep).
            Demonstrates: Substitution group pattern.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Buyer" type="party:Organization_t">
        <xs:annotation>
          <xs:documentation>Buying organization.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Seller" type="party:Organization_t">
        <xs:annotation>
          <xs:documentation>Selling organization.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderItems" type="po:OrderItems_t">
        <xs:annotation>
          <xs:documentation>Line items in the order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PricingDetails" type="po:PricingDetails_t">
        <xs:annotation>
          <xs:documentation>Pricing breakdown and calculations.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="fin:PaymentMethod" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Payment method using substitution group from common-financial.
            Demonstrates: Cross-schema substitution group usage.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PaymentTerms" type="fin:PaymentTerms_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Payment terms and conditions.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TaxDetails" type="fin:TaxDetails_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Tax calculation details.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShippingDetails" type="po:ShippingDetails_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Shipping and delivery information.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomsDetails" type="po:CustomsDetails_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Customs information for international shipments.
            Demonstrates: Abstract element in sequence (maxOccurs=1).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DeliveryPreferences" type="po:DeliveryPreferences_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Delivery preferences and instructions.
            Demonstrates: Abstract in choice (maxOccurs=1) + Nested choice (maxOccurs=1).
          </xs:documentation>
        </xs:annotation>
      </xs:element>

      <xs:element name="SpecialInstructions" type="po:SpecialInstructions_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Special instructions with nested choice construct.
            Demonstrates: Complex choice with abstract elements.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ApprovalWorkflow" type="po:ApprovalWorkflow_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Multi-stage approval workflow.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Attachments" type="po:Attachments_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Document attachments.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Notes" type="ct:Note_t" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Additional notes and comments.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attributeGroup ref="ct:AuditAttributes"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ORDER TYPE SUBSTITUTION GROUP (4 LEVELS) -->
  <!-- ================================================================ -->

  <!-- Level 1: Abstract Base -->
  <xs:element name="OrderType" type="po:Abstract_OrderType_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base for order type substitution group.
        Level 1 of 4-level substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="Abstract_OrderType_t" abstract="true">
    <xs:annotation>
      <xs:documentation>Abstract base type for all order types.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="OrderCategory" type="po:OrderCategory_t">
        <xs:annotation>
          <xs:documentation>High-level order category.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Priority" type="po:OrderPriority_t">
        <xs:annotation>
          <xs:documentation>Order priority level.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Level 2: Standard Order -->
  <xs:element name="StandardOrder" substitutionGroup="po:OrderType" type="po:StandardOrder_t">
    <xs:annotation>
      <xs:documentation>
        Standard order type.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="StandardOrder_t">
    <xs:annotation>
      <xs:documentation>Standard order with normal processing.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:Abstract_OrderType_t">
        <xs:sequence>
          <xs:element name="ProcessingTime" type="dt:Duration_t">
            <xs:annotation>
              <xs:documentation>Expected processing time.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StandardFeatures" type="po:StandardFeatures_t">
            <xs:annotation>
              <xs:documentation>Standard order features.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Express Order (extends StandardOrder) -->
  <xs:element name="ExpressOrder" substitutionGroup="po:StandardOrder" type="po:ExpressOrder_t">
    <xs:annotation>
      <xs:documentation>
        Express order with expedited processing.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ExpressOrder_t">
    <xs:annotation>
      <xs:documentation>Express order extending standard order.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:StandardOrder_t">
        <xs:sequence>
          <xs:element name="ExpressLevel" type="po:ExpressLevel_t">
            <xs:annotation>
              <xs:documentation>Level of express service.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExpressFee" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Additional fee for express service.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="GuaranteedDelivery" type="xs:dateTime">
            <xs:annotation>
              <xs:documentation>Guaranteed delivery date/time.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 4: Same-Day Order (extends ExpressOrder) -->
  <xs:element name="SameDayOrder" substitutionGroup="po:ExpressOrder" type="po:SameDayOrder_t">
    <xs:annotation>
      <xs:documentation>
        Same-day delivery order.
        Level 4 of substitution hierarchy (deepest level).
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="SameDayOrder_t">
    <xs:annotation>
      <xs:documentation>Same-day order extending express order.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:ExpressOrder_t">
        <xs:sequence>
          <xs:element name="DeliveryWindow" type="dt:TimeWindow_t">
            <xs:annotation>
              <xs:documentation>Specific delivery time window.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CourierAssignment" type="po:CourierAssignment_t">
            <xs:annotation>
              <xs:documentation>Assigned courier details.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RealTimeTracking" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Real-time tracking enabled.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Rush Order (parallel branch) -->
  <xs:element name="RushOrder" substitutionGroup="po:OrderType" type="po:RushOrder_t">
    <xs:annotation>
      <xs:documentation>
        Rush order type (parallel to StandardOrder).
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="RushOrder_t">
    <xs:annotation>
      <xs:documentation>Rush order with priority processing.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:Abstract_OrderType_t">
        <xs:sequence>
          <xs:element name="RushReason" type="po:RushReason_t">
            <xs:annotation>
              <xs:documentation>Reason for rush processing.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RushFee" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Rush processing fee.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RequiredByDate" type="xs:dateTime">
            <xs:annotation>
              <xs:documentation>Required completion date/time.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Emergency Order (extends RushOrder) -->
  <xs:element name="EmergencyOrder" substitutionGroup="po:RushOrder" type="po:EmergencyOrder_t">
    <xs:annotation>
      <xs:documentation>
        Emergency order with highest priority.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="EmergencyOrder_t">
    <xs:annotation>
      <xs:documentation>Emergency order extending rush order.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:RushOrder_t">
        <xs:sequence>
          <xs:element name="EmergencyContact" type="party:ContactInfo_t">
            <xs:annotation>
              <xs:documentation>Emergency contact person.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="EmergencyAuthorization" type="po:EmergencyAuthorization_t">
            <xs:annotation>
              <xs:documentation>Authorization for emergency processing.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ImmediateProcessing" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Process immediately without queue.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Bulk Order (parallel branch) -->
  <xs:element name="BulkOrder" substitutionGroup="po:OrderType" type="po:BulkOrder_t">
    <xs:annotation>
      <xs:documentation>
        Bulk order type for large quantities.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="BulkOrder_t">
    <xs:annotation>
      <xs:documentation>Bulk order with volume discounts.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:Abstract_OrderType_t">
        <xs:sequence>
          <xs:element name="MinimumQuantity" type="ct:Quantity_t">
            <xs:annotation>
              <xs:documentation>Minimum quantity for bulk pricing.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="VolumeDiscount" type="ct:Percentage_t">
            <xs:annotation>
              <xs:documentation>Volume discount percentage.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DeliverySchedule" type="dt:Schedule_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Scheduled delivery for bulk items.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Wholesale Order (extends BulkOrder) -->
  <xs:element name="WholesaleOrder" substitutionGroup="po:BulkOrder" type="po:WholesaleOrder_t">
    <xs:annotation>
      <xs:documentation>
        Wholesale order for resellers.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="WholesaleOrder_t">
    <xs:annotation>
      <xs:documentation>Wholesale order extending bulk order.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="po:BulkOrder_t">
        <xs:sequence>
          <xs:element name="ResellerID" type="xs:string">
            <xs:annotation>
              <xs:documentation>Reseller identification number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="WholesalePricing" type="po:WholesalePricing_t">
            <xs:annotation>
              <xs:documentation>Wholesale pricing structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ResellerAgreement" type="ct:ReferenceNumber_t">
            <xs:annotation>
              <xs:documentation>Reference to reseller agreement.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ORDER HEADER -->
  <!-- ================================================================ -->

  <xs:complexType name="OrderHeader_t">
    <xs:annotation>
      <xs:documentation>
        Order header with identification and metadata.
        Contains 20+ attributes for comprehensive tracking.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="OrderID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique order identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderNumber" type="ct:ReferenceNumber_t">
        <xs:annotation>
          <xs:documentation>Human-readable order number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time order was created.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="RequestedDeliveryDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Requested delivery date.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PromisedDeliveryDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Promised delivery date from seller.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderStatus" type="po:OrderStatus_t">
        <xs:annotation>
          <xs:documentation>Current status of the order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Currency" type="ct:CurrencyCode_t">
        <xs:annotation>
          <xs:documentation>Currency for all amounts in this order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Language" type="ct:LanguageCode_t">
        <xs:annotation>
          <xs:documentation>Language for order documents.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderSource" type="po:OrderSource_t">
        <xs:annotation>
          <xs:documentation>Source/channel of the order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SalesRepresentative" type="party:Person_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Sales representative handling the order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomerReference" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Customer's reference number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QuoteReference" type="ct:ReferenceNumber_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reference to related quote.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ContractReference" type="ct:ReferenceNumber_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reference to master contract.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PreviousOrderReference" type="ct:UUID_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reference to previous related order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BuyerContact" type="party:ContactInfo_t">
        <xs:annotation>
          <xs:documentation>Primary buyer contact.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SellerContact" type="party:ContactInfo_t">
        <xs:annotation>
          <xs:documentation>Primary seller contact.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingCycle" type="po:BillingCycle_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Billing cycle for recurring orders.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="FiscalYear" type="xs:gYear" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Fiscal year for accounting.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CostCenter" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Cost center for internal accounting.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProjectCode" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Project code for tracking.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attribute name="isTestOrder" type="xs:boolean" default="false">
      <xs:annotation>
        <xs:documentation>Indicates if this is a test order.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ORDER ITEMS -->
  <!-- ================================================================ -->

  <xs:complexType name="OrderItems_t">
    <xs:annotation>
      <xs:documentation>
        Collection of order line items.
        Each item has 25+ fields for complete product specification.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="OrderItem" type="po:OrderItem_t" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Individual order line item.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="totalItems" type="xs:positiveInteger" use="optional">
      <xs:annotation>
        <xs:documentation>Total number of line items.</xs:documentation>
      </xs:annotation>
    </xs:attribute>
  </xs:complexType>

  <xs:complexType name="OrderItem_t">
    <xs:annotation>
      <xs:documentation>
        Individual order line item with complete product details.
        Demonstrates: Complex nested structure with choice constructs.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LineNumber" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>Line item number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProductID" type="xs:string">
        <xs:annotation>
          <xs:documentation>Product identifier (SKU).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProductName" type="xs:string">
        <xs:annotation>
          <xs:documentation>Product name/description.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProductCategory" type="po:ProductCategory_t">
        <xs:annotation>
          <xs:documentation>Product category classification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Manufacturer" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Product manufacturer.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ManufacturerPartNumber" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Manufacturer's part number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UPC" type="po:UPC_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Universal Product Code.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Quantity" type="ct:Quantity_t">
        <xs:annotation>
          <xs:documentation>Ordered quantity.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UnitOfMeasure" type="po:UnitOfMeasure_t">
        <xs:annotation>
          <xs:documentation>Unit of measure for quantity.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UnitPrice" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>Price per unit.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ExtendedPrice" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>Extended price (quantity × unit price).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Discounts" type="po:Discounts_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Applicable discounts for this item.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TaxDetails" type="fin:TaxDetails_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Tax details for this item.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NetPrice" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>Net price after discounts before tax.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TotalPrice" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>Total price including tax.</xs:documentation>
