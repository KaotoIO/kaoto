  <!-- ================================================================ -->
  <!-- DELIVERY PREFERENCES TYPE (maxOccurs=1 Patterns in Choice) -->
  <!-- ================================================================ -->

  <xs:complexType name="DeliveryPreferences_t">
    <xs:annotation>
      <xs:documentation>
        Delivery preferences and special instructions.
        Demonstrates: Abstract in choice (maxOccurs=1) + Nested choice (maxOccurs=1).
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="PreferredDeliveryDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Preferred delivery date.</xs:documentation>
        </xs:annotation>
      </xs:element>
      
      <!-- PATTERNS: Abstract in choice (maxOccurs=1) + Nested choice (maxOccurs=1) -->
      <xs:choice minOccurs="0">
        <!-- Pattern 1: Abstract element in choice with maxOccurs=1 -->
        <xs:element ref="fin:PaymentMethod">
          <xs:annotation>
            <xs:documentation>
              PATTERN: Abstract element in choice (maxOccurs=1).
              Single payment preference.
              Demonstrates: Substitution group as choice option with single occurrence.
              Complements: ShippingDetails/PaymentMethod (maxOccurs=unbounded).
            </xs:documentation>
          </xs:annotation>
        </xs:element>
        
        <!-- Pattern 2: Nested choice with maxOccurs=1 -->
        <xs:choice>
          <xs:element name="StandardPaymentPreference" type="xs:string">
            <xs:annotation>
              <xs:documentation>PATTERN: Nested choice (maxOccurs=1) - standard preference.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExpressPaymentPreference" type="xs:string">
            <xs:annotation>
              <xs:documentation>PATTERN: Nested choice (maxOccurs=1) - express preference.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:choice>
        
        <!-- Regular element -->
        <xs:element name="CustomPaymentPreference" type="xs:string">
          <xs:annotation>
            <xs:documentation>Custom payment preference.</xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:choice>
      
      <xs:element name="SpecialInstructions" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Special delivery instructions.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SignatureRequired" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>Whether signature is required for delivery.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>


