<?xml version="1.0" encoding="UTF-8"?>
<!--
  Account Information Schema (Source Param2)
  
  Purpose: Comprehensive customer account management schema with enterprise complexity
  Demonstrates: Substitution groups for account types, profile management,
                authentication methods, xs:extension, xs:restriction, xs:import patterns
  
  This schema represents complex account scenarios including multiple account types,
  user profiles, authentication mechanisms, preferences, and security settings.
  Follows enterprise patterns similar to FIXML/FPML/FMM.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:acct="http://www.kaoto.io/account"
           xmlns:ct="http://www.kaoto.io/common/types"
           xmlns:addr="http://www.kaoto.io/common/address"
           xmlns:party="http://www.kaoto.io/common/party"
           xmlns:fin="http://www.kaoto.io/common/financial"
           xmlns:dt="http://www.kaoto.io/common/datetime"
           targetNamespace="http://www.kaoto.io/account"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <!-- ================================================================ -->
  <!-- IMPORTS - Cross-namespace references -->
  <!-- ================================================================ -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common/common-types.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/address"
             schemaLocation="common/common-address.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/party"
             schemaLocation="common/common-party.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/financial"
             schemaLocation="common/common-financial.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/datetime"
             schemaLocation="common/common-datetime.xsd"/>

  <!-- ================================================================ -->
  <!-- DOCUMENTATION -->
  <!-- ================================================================ -->
  <xs:annotation>
    <xs:documentation xml:lang="en">
      Account Information Schema for Kaoto DataMapper Enterprise Testing
      
      This schema demonstrates enterprise-level account management including:
      - 4-level substitution groups for account types
      - Complex user profile management
      - Multi-factor authentication mechanisms
      - Preference and settings management
      - Security and compliance features
      
      Version: 1.0
      Namespace: http://www.kaoto.io/account
      
      Total complexity: ~1750 lines
      Demonstrates: Advanced account patterns with substitution groups
    </xs:documentation>
  </xs:annotation>

  <!-- ================================================================ -->
  <!-- ROOT ELEMENT -->
  <!-- ================================================================ -->

  <xs:element name="AccountInfo" type="acct:AccountInfo_t">
    <xs:annotation>
      <xs:documentation>
        Root element for account information document.
        Contains complete account details for a customer.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================ -->
  <!-- ACCOUNT INFO TYPE -->
  <!-- ================================================================ -->

  <xs:complexType name="AccountInfo_t">
    <xs:annotation>
      <xs:documentation>
        Main account information structure.
        Contains account details, profiles, preferences, and security settings.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AccountHeader" type="acct:AccountHeader_t">
        <xs:annotation>
          <xs:documentation>Account header with identification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="acct:Account">
        <xs:annotation>
          <xs:documentation>
            Account using substitution group (4 levels deep).
            Demonstrates: Account type substitution hierarchy.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountHolder" type="party:Person_t">
        <xs:annotation>
          <xs:documentation>Primary account holder.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UserProfile" type="acct:UserProfile_t">
        <xs:annotation>
          <xs:documentation>User profile information.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ContactInformation" type="acct:ContactInformation_t">
        <xs:annotation>
          <xs:documentation>Contact information for account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Addresses" type="acct:Addresses_t">
        <xs:annotation>
          <xs:documentation>Collection of addresses.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Authentication" type="acct:Authentication_t">
        <xs:annotation>
          <xs:documentation>Authentication settings and methods.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Security" type="acct:Security_t">
        <xs:annotation>
          <xs:documentation>Security settings and policies.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Preferences" type="acct:Preferences_t">
        <xs:annotation>
          <xs:documentation>User preferences and settings.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Subscriptions" type="acct:Subscriptions_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Active subscriptions.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LoyaltyProgram" type="acct:LoyaltyProgram_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Loyalty program membership.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PaymentMethods" type="acct:PaymentMethods_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Saved payment methods.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Compliance" type="acct:Compliance_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Compliance and regulatory information.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ActivityLog" type="acct:ActivityLog_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Account activity log.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Notes" type="ct:Note_t" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Additional account notes.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attributeGroup ref="ct:AuditAttributes"/>
    <xs:attribute name="version" type="xs:string" use="required"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ACCOUNT HEADER -->
  <!-- ================================================================ -->

  <xs:complexType name="AccountHeader_t">
    <xs:annotation>
      <xs:documentation>Account header with identification and metadata.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AccountID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique account identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountNumber" type="xs:string">
        <xs:annotation>
          <xs:documentation>Human-readable account number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CreationDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time account was created.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LastModifiedDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time account was last modified.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LastLoginDate" type="xs:dateTime" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Date/time of last login.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountStatus" type="acct:AccountStatus_t">
        <xs:annotation>
          <xs:documentation>Current account status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StatusReason" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reason for current status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="VerificationStatus" type="acct:VerificationStatus_t">
        <xs:annotation>
          <xs:documentation>Account verification status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="VerificationDate" type="xs:dateTime" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Date account was verified.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ExpiryDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Account expiry date if applicable.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- ACCOUNT TYPE SUBSTITUTION GROUP (4 LEVELS) -->
  <!-- ================================================================ -->

  <!-- Level 1: Abstract Base -->
  <xs:element name="Account" type="acct:Abstract_Account_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base for account substitution group.
        Level 1 of 4-level substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="Abstract_Account_t" abstract="true">
    <xs:annotation>
      <xs:documentation>Abstract base type for all accounts.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AccountType" type="acct:AccountType_t">
        <xs:annotation>
          <xs:documentation>Type of account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountTier" type="acct:AccountTier_t">
        <xs:annotation>
          <xs:documentation>Account tier/level.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Currency" type="ct:CurrencyCode_t">
        <xs:annotation>
          <xs:documentation>Primary currency for account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Language" type="ct:LanguageCode_t">
        <xs:annotation>
          <xs:documentation>Preferred language.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TimeZone" type="xs:string">
        <xs:annotation>
          <xs:documentation>Account time zone.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Level 2: Personal Account -->
  <xs:element name="PersonalAccount" substitutionGroup="acct:Account" type="acct:PersonalAccount_t">
    <xs:annotation>
      <xs:documentation>
        Personal/individual account type.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="PersonalAccount_t">
    <xs:annotation>
      <xs:documentation>Personal account for individual users.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:Abstract_Account_t">
        <xs:sequence>
          <xs:element name="DateOfBirth" type="xs:date" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Account holder date of birth.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Gender" type="acct:Gender_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Account holder gender.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MaritalStatus" type="acct:MaritalStatus_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Marital status.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Occupation" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Occupation.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="EmploymentStatus" type="acct:EmploymentStatus_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Employment status.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AnnualIncome" type="acct:IncomeRange_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Annual income range.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Premium Personal Account (extends PersonalAccount) -->
  <xs:element name="PremiumPersonalAccount" substitutionGroup="acct:PersonalAccount" type="acct:PremiumPersonalAccount_t">
    <xs:annotation>
      <xs:documentation>
        Premium personal account with enhanced features.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="PremiumPersonalAccount_t">
    <xs:annotation>
      <xs:documentation>Premium personal account extending personal account.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:PersonalAccount_t">
        <xs:sequence>
          <xs:element name="PremiumFeatures" type="acct:PremiumFeatures_t">
            <xs:annotation>
              <xs:documentation>Premium account features.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DedicatedSupport" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Dedicated support access.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AccountManager" type="party:Person_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Dedicated account manager.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PriorityProcessing" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Priority processing for transactions.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 4: VIP Account (extends PremiumPersonalAccount) -->
  <xs:element name="VIPAccount" substitutionGroup="acct:PremiumPersonalAccount" type="acct:VIPAccount_t">
    <xs:annotation>
      <xs:documentation>
        VIP account with exclusive benefits.
        Level 4 of substitution hierarchy (deepest level).
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="VIPAccount_t">
    <xs:annotation>
      <xs:documentation>VIP account with exclusive features.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:PremiumPersonalAccount_t">
        <xs:sequence>
          <xs:element name="VIPLevel" type="acct:VIPLevel_t">
            <xs:annotation>
              <xs:documentation>VIP tier level.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ConciergeService" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Concierge service access.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExclusiveOffers" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Access to exclusive offers.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="InvitationOnlyEvents" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Invitation to exclusive events.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PersonalShopper" type="party:Person_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Assigned personal shopper.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Business Account (parallel branch) -->
  <xs:element name="BusinessAccount" substitutionGroup="acct:Account" type="acct:BusinessAccount_t">
    <xs:annotation>
      <xs:documentation>
        Business/corporate account type.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="BusinessAccount_t">
    <xs:annotation>
      <xs:documentation>Business account for organizations.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:Abstract_Account_t">
        <xs:sequence>
          <xs:element name="CompanyName" type="xs:string">
            <xs:annotation>
              <xs:documentation>Legal company name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TaxID" type="xs:string">
            <xs:annotation>
              <xs:documentation>Tax identification number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="BusinessType" type="acct:BusinessType_t">
            <xs:annotation>
              <xs:documentation>Type of business.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="IndustryCode" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Industry classification code.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="YearEstablished" type="xs:gYear" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Year business was established.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NumberOfEmployees" type="acct:EmployeeRange_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Number of employees range.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AnnualRevenue" type="acct:RevenueRange_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Annual revenue range.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AuthorizedSigners" type="acct:AuthorizedSigners_t">
            <xs:annotation>
              <xs:documentation>Authorized signers for account.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Enterprise Account (extends BusinessAccount) -->
  <xs:element name="EnterpriseAccount" substitutionGroup="acct:BusinessAccount" type="acct:EnterpriseAccount_t">
    <xs:annotation>
      <xs:documentation>
        Enterprise account for large organizations.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="EnterpriseAccount_t">
    <xs:annotation>
      <xs:documentation>Enterprise account with advanced features.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:BusinessAccount_t">
        <xs:sequence>
          <xs:element name="EnterpriseFeatures" type="acct:EnterpriseFeatures_t">
            <xs:annotation>
              <xs:documentation>Enterprise-specific features.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MultiLocationSupport" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Support for multiple locations.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DepartmentStructure" type="acct:DepartmentStructure_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Organizational department structure.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CustomIntegrations" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Custom integration support.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SLA" type="acct:ServiceLevelAgreement_t">
            <xs:annotation>
              <xs:documentation>Service level agreement.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Reseller Account (parallel branch) -->
  <xs:element name="ResellerAccount" substitutionGroup="acct:Account" type="acct:ResellerAccount_t">
    <xs:annotation>
      <xs:documentation>
        Reseller/partner account type.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ResellerAccount_t">
    <xs:annotation>
      <xs:documentation>Reseller account for partners.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:Abstract_Account_t">
        <xs:sequence>
          <xs:element name="ResellerID" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique reseller identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PartnerLevel" type="acct:PartnerLevel_t">
            <xs:annotation>
              <xs:documentation>Partner tier level.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CommissionRate" type="ct:Percentage_t">
            <xs:annotation>
              <xs:documentation>Commission rate percentage.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ResellerAgreement" type="ct:ReferenceNumber_t">
            <xs:annotation>
              <xs:documentation>Reference to reseller agreement.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TerritoryRestrictions" type="acct:TerritoryRestrictions_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Geographic territory restrictions.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProductCategories" type="acct:ProductCategories_t">
            <xs:annotation>
              <xs:documentation>Authorized product categories.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Premium Reseller (extends ResellerAccount) -->
  <xs:element name="PremiumResellerAccount" substitutionGroup="acct:ResellerAccount" type="acct:PremiumResellerAccount_t">
    <xs:annotation>
      <xs:documentation>
        Premium reseller with enhanced benefits.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="PremiumResellerAccount_t">
    <xs:annotation>
      <xs:documentation>Premium reseller account.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="acct:ResellerAccount_t">
        <xs:sequence>
          <xs:element name="EnhancedCommissionRate" type="ct:Percentage_t">
            <xs:annotation>
              <xs:documentation>Enhanced commission rate.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="MarketingSupport" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Marketing support provided.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TrainingPrograms" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Access to training programs.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DedicatedPartnerManager" type="party:Person_t">
            <xs:annotation>
              <xs:documentation>Dedicated partner manager.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- USER PROFILE -->
  <!-- ================================================================ -->

  <xs:complexType name="UserProfile_t">
    <xs:annotation>
      <xs:documentation>
        User profile with 25+ fields for complete user information.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="Username" type="xs:string">
        <xs:annotation>
          <xs:documentation>Unique username.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DisplayName" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Display name for UI.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="FirstName" type="xs:string">
        <xs:annotation>
          <xs:documentation>First name.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="MiddleName" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Middle name.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LastName" type="xs:string">
        <xs:annotation>
          <xs:documentation>Last name.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Suffix" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Name suffix (Jr., Sr., III, etc.).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Title" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Professional title.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ProfilePicture" type="ct:URL_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>URL to profile picture.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Bio" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>User biography/description.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Website" type="ct:URL_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Personal/business website.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SocialMedia" type="acct:SocialMediaProfiles_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Social media profiles.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Interests" type="acct:Interests_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>User interests and hobbies.</xs:documentation>
