<?xml version="1.0" encoding="UTF-8"?>
<!--
  Stock Information Schema (Source Param4)
  
  Purpose: Comprehensive inventory and stock management schema with enterprise complexity
  Demonstrates: Substitution groups for stock types, inventory tracking, warehouse management,
                xs:extension, xs:restriction, xs:import patterns
  
  This schema represents complex inventory scenarios including multiple stock types,
  warehouse locations, inventory movements, replenishment, and forecasting.
  Follows enterprise patterns similar to FIXML/FPML/FMM.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:stock="http://www.kaoto.io/stock"
           xmlns:ct="http://www.kaoto.io/common/types"
           xmlns:addr="http://www.kaoto.io/common/address"
           xmlns:party="http://www.kaoto.io/common/party"
           xmlns:fin="http://www.kaoto.io/common/financial"
           xmlns:dt="http://www.kaoto.io/common/datetime"
           targetNamespace="http://www.kaoto.io/stock"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <!-- ================================================================ -->
  <!-- IMPORTS - Cross-namespace references -->
  <!-- ================================================================ -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common/common-types.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/address"
             schemaLocation="common/common-address.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/party"
             schemaLocation="common/common-party.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/financial"
             schemaLocation="common/common-financial.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/datetime"
             schemaLocation="common/common-datetime.xsd"/>

  <!-- ================================================================ -->
  <!-- DOCUMENTATION -->
  <!-- ================================================================ -->
  <xs:annotation>
    <xs:documentation xml:lang="en">
      Stock Information Schema for Kaoto DataMapper Enterprise Testing
      
      This schema demonstrates enterprise-level inventory management including:
      - 4-level substitution groups for stock item types
      - Complex warehouse and location management
      - Inventory movements and transactions
      - Replenishment and forecasting
      - Multi-location inventory tracking
      
      Version: 1.0
      Namespace: http://www.kaoto.io/stock
      
      Total complexity: ~1750 lines
      Demonstrates: Advanced inventory patterns with substitution groups
    </xs:documentation>
  </xs:annotation>

  <!-- ================================================================ -->
  <!-- ROOT ELEMENT -->
  <!-- ================================================================ -->

  <xs:element name="StockInfo" type="stock:StockInfo_t">
    <xs:annotation>
      <xs:documentation>
        Root element for stock information document.
        Contains complete inventory and stock details.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================ -->
  <!-- STOCK INFO TYPE -->
  <!-- ================================================================ -->

  <xs:complexType name="StockInfo_t">
    <xs:annotation>
      <xs:documentation>
        Main stock information structure.
        Contains inventory items, locations, movements, and forecasting.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="StockHeader" type="stock:StockHeader_t">
        <xs:annotation>
          <xs:documentation>Stock header with identification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InventoryItems" type="stock:InventoryItems_t">
        <xs:annotation>
          <xs:documentation>
            Collection of inventory items.
            Demonstrates: Stock item type substitution group (4 levels).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="WarehouseLocations" type="stock:WarehouseLocations_t">
        <xs:annotation>
          <xs:documentation>Warehouse and storage locations.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InventoryMovements" type="stock:InventoryMovements_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Inventory movement transactions.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StockLevels" type="stock:StockLevels_t">
        <xs:annotation>
          <xs:documentation>Current stock levels across locations.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ReplenishmentPlanning" type="stock:ReplenishmentPlanning_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Replenishment planning and forecasting.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StockValuation" type="stock:StockValuation_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Stock valuation and costing.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="QualityControl" type="stock:QualityControl_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Quality control and inspection records.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StockAdjustments" type="stock:StockAdjustments_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Stock adjustments and corrections.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Notes" type="ct:Note_t" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Additional stock notes.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attributeGroup ref="ct:AuditAttributes"/>
    <xs:attribute name="version" type="xs:string" use="required"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- STOCK HEADER -->
  <!-- ================================================================ -->

  <xs:complexType name="StockHeader_t">
    <xs:annotation>
      <xs:documentation>Stock header with identification and metadata.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="StockID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique stock record identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StockNumber" type="ct:ReferenceNumber_t">
        <xs:annotation>
          <xs:documentation>Human-readable stock number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SnapshotDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time of stock snapshot.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="FiscalPeriod" type="stock:FiscalPeriod_t">
        <xs:annotation>
          <xs:documentation>Fiscal period for stock reporting.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Currency" type="ct:CurrencyCode_t">
        <xs:annotation>
          <xs:documentation>Currency for stock valuation.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StockStatus" type="stock:StockStatus_t">
        <xs:annotation>
          <xs:documentation>Overall stock status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderReference" type="ct:UUID_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reference to related order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LastStocktakeDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Date of last physical stocktake.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="NextStocktakeDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Scheduled date for next stocktake.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="FiscalPeriod_t">
    <xs:sequence>
      <xs:element name="FiscalYear" type="xs:gYear"/>
      <xs:element name="Period" type="xs:positiveInteger"/>
      <xs:element name="StartDate" type="xs:date"/>
      <xs:element name="EndDate" type="xs:date"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- INVENTORY ITEMS COLLECTION -->
  <!-- ================================================================ -->

  <xs:complexType name="InventoryItems_t">
    <xs:annotation>
      <xs:documentation>Collection of inventory items with various types.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="stock:InventoryItem" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Individual inventory item (uses substitution group).
            Demonstrates: 4-level stock item type hierarchy.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="totalItems" type="xs:positiveInteger" use="optional"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- INVENTORY ITEM TYPE SUBSTITUTION GROUP (4 LEVELS) -->
  <!-- ================================================================ -->

  <!-- Level 1: Abstract Base -->
  <xs:element name="InventoryItem" type="stock:Abstract_InventoryItem_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base for inventory item substitution group.
        Level 1 of 4-level substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="Abstract_InventoryItem_t" abstract="true">
    <xs:annotation>
      <xs:documentation>Abstract base type for all inventory items.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ItemID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique item identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SKU" type="xs:string">
        <xs:annotation>
          <xs:documentation>Stock keeping unit.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ItemDescription" type="xs:string">
        <xs:annotation>
          <xs:documentation>Item description.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ItemCategory" type="stock:ItemCategory_t">
        <xs:annotation>
          <xs:documentation>Item category classification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="UnitOfMeasure" type="xs:string">
        <xs:annotation>
          <xs:documentation>Unit of measure.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ItemStatus" type="stock:ItemStatus_t">
        <xs:annotation>
          <xs:documentation>Current item status.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Level 2: Standard Item -->
  <xs:element name="StandardItem" substitutionGroup="stock:InventoryItem" type="stock:StandardItem_t">
    <xs:annotation>
      <xs:documentation>
        Standard inventory item.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="StandardItem_t">
    <xs:annotation>
      <xs:documentation>Standard inventory item with basic tracking.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:Abstract_InventoryItem_t">
        <xs:sequence>
          <xs:element name="Manufacturer" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Item manufacturer.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ManufacturerPartNumber" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Manufacturer part number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="UPC" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Universal product code.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Weight" type="ct:Weight_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Item weight.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Dimensions" type="stock:Dimensions_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Item dimensions.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ReorderPoint" type="ct:Quantity_t">
            <xs:annotation>
              <xs:documentation>Reorder point quantity.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ReorderQuantity" type="ct:Quantity_t">
            <xs:annotation>
              <xs:documentation>Standard reorder quantity.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Serialized Item (extends StandardItem) -->
  <xs:element name="SerializedItem" substitutionGroup="stock:StandardItem" type="stock:SerializedItem_t">
    <xs:annotation>
      <xs:documentation>
        Serialized inventory item with unique serial numbers.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="SerializedItem_t">
    <xs:annotation>
      <xs:documentation>Serialized item extending standard item.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:StandardItem_t">
        <xs:sequence>
          <xs:element name="SerialNumbers" type="stock:SerialNumbers_t">
            <xs:annotation>
              <xs:documentation>Serial numbers for this item.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SerialTracking" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Serial number tracking enabled.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="WarrantyTracking" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Warranty tracking by serial number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="WarrantyPeriod" type="dt:Duration_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Standard warranty period.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 4: High-Value Serialized Item (extends SerializedItem) -->
  <xs:element name="HighValueSerializedItem" substitutionGroup="stock:SerializedItem" type="stock:HighValueSerializedItem_t">
    <xs:annotation>
      <xs:documentation>
        High-value serialized item with enhanced tracking.
        Level 4 of substitution hierarchy (deepest level).
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="HighValueSerializedItem_t">
    <xs:annotation>
      <xs:documentation>High-value item with enhanced security and tracking.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:SerializedItem_t">
        <xs:sequence>
          <xs:element name="InsuranceRequired" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Insurance required for this item.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="InsuredValue" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Insured value per unit.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SecurityLevel" type="stock:SecurityLevel_t">
            <xs:annotation>
              <xs:documentation>Security level required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RestrictedAccess" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Restricted access required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AuditFrequency" type="stock:AuditFrequency_t">
            <xs:annotation>
              <xs:documentation>Required audit frequency.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Lot-Tracked Item (parallel branch) -->
  <xs:element name="LotTrackedItem" substitutionGroup="stock:InventoryItem" type="stock:LotTrackedItem_t">
    <xs:annotation>
      <xs:documentation>
        Lot/batch tracked inventory item.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="LotTrackedItem_t">
    <xs:annotation>
      <xs:documentation>Lot-tracked item for batch management.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:Abstract_InventoryItem_t">
        <xs:sequence>
          <xs:element name="LotNumbers" type="stock:LotNumbers_t">
            <xs:annotation>
              <xs:documentation>Lot/batch numbers.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LotTracking" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Lot tracking enabled.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ShelfLife" type="dt:Duration_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Standard shelf life.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExpiryTracking" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Expiry date tracking enabled.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Perishable Item (extends LotTrackedItem) -->
  <xs:element name="PerishableItem" substitutionGroup="stock:LotTrackedItem" type="stock:PerishableItem_t">
    <xs:annotation>
      <xs:documentation>
        Perishable item with expiry tracking.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="PerishableItem_t">
    <xs:annotation>
      <xs:documentation>Perishable item requiring temperature control.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:LotTrackedItem_t">
        <xs:sequence>
          <xs:element name="StorageTemperature" type="stock:TemperatureRange_t">
            <xs:annotation>
              <xs:documentation>Required storage temperature range.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TemperatureMonitoring" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Temperature monitoring required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FIFO" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>First-in-first-out rotation required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExpiryAlertDays" type="xs:positiveInteger">
            <xs:annotation>
              <xs:documentation>Days before expiry to trigger alert.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Hazardous Item (parallel branch) -->
  <xs:element name="HazardousItem" substitutionGroup="stock:InventoryItem" type="stock:HazardousItem_t">
    <xs:annotation>
      <xs:documentation>
        Hazardous material item.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="HazardousItem_t">
    <xs:annotation>
      <xs:documentation>Hazardous item requiring special handling.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:Abstract_InventoryItem_t">
        <xs:sequence>
          <xs:element name="UNNumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>UN hazard identification number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="HazardClass" type="xs:string">
            <xs:annotation>
              <xs:documentation>Hazard classification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PackingGroup" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Packing group.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProperShippingName" type="xs:string">
            <xs:annotation>
              <xs:documentation>Proper shipping name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SafetyDataSheet" type="ct:URL_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Link to safety data sheet.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SpecialHandling" type="xs:string">
            <xs:annotation>
              <xs:documentation>Special handling requirements.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StorageRestrictions" type="stock:StorageRestrictions_t">
            <xs:annotation>
              <xs:documentation>Storage restrictions and requirements.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Controlled Substance (extends HazardousItem) -->
  <xs:element name="ControlledSubstance" substitutionGroup="stock:HazardousItem" type="stock:ControlledSubstance_t">
    <xs:annotation>
      <xs:documentation>
        Controlled substance with regulatory tracking.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ControlledSubstance_t">
    <xs:annotation>
      <xs:documentation>Controlled substance requiring regulatory compliance.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="stock:HazardousItem_t">
        <xs:sequence>
          <xs:element name="ControlSchedule" type="stock:ControlSchedule_t">
            <xs:annotation>
              <xs:documentation>Controlled substance schedule.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DEANumber" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>DEA registration number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RegulatoryTracking" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Regulatory tracking required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ChainOfCustody" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Chain of custody documentation required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AuditTrail" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Complete audit trail required.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- SUPPORTING TYPES FOR INVENTORY ITEMS -->
  <!-- ================================================================ -->

  <xs:complexType name="Dimensions_t">
    <xs:sequence>
      <xs:element name="Length" type="ct:Dimension_t"/>
      <xs:element name="Width" type="ct:Dimension_t"/>
      <xs:element name="Height" type="ct:Dimension_t"/>
      <xs:element name="DimensionUnit" type="ct:DimensionUnit_t"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="SerialNumbers_t">
    <xs:sequence>
      <xs:element name="SerialNumber" type="stock:SerialNumber_t" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="SerialNumber_t">
    <xs:sequence>
      <xs:element name="SerialID" type="xs:string"/>
      <xs:element name="ManufactureDate" type="xs:date" minOccurs="0"/>
      <xs:element name="WarrantyExpiry" type="xs:date" minOccurs="0"/>
      <xs:element name="LocationCode" type="xs:string" minOccurs="0"/>
      <xs:element name="Status" type="stock:SerialStatus_t"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LotNumbers_t">
    <xs:sequence>
      <xs:element name="LotNumber" type="stock:LotNumber_t" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="LotNumber_t">
    <xs:sequence>
      <xs:element name="LotID" type="xs:string"/>
      <xs:element name="ManufactureDate" type="xs:date"/>
      <xs:element name="ExpiryDate" type="xs:date" minOccurs="0"/>
      <xs:element name="Quantity" type="ct:Quantity_t"/>
      <xs:element name="LocationCode" type="xs:string" minOccurs="0"/>
      <xs:element name="Status" type="stock:LotStatus_t"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="TemperatureRange_t">
    <xs:sequence>
      <xs:element name="MinTemperature" type="xs:decimal"/>
      <xs:element name="MaxTemperature" type="xs:decimal"/>
      <xs:element name="TemperatureUnit" type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="StorageRestrictions_t">
    <xs:sequence>
      <xs:element name="SeparationRequired" type="xs:boolean" default="true"/>
      <xs:element name="IncompatibleWith" type="stock:IncompatibleMaterials_t" minOccurs="0"/>
      <xs:element name="VentilationRequired" type="xs:boolean" default="false"/>
      <xs:element name="FireSuppression" type="xs:string" minOccurs="0"/>
      <xs:element name="MaxStackHeight" type="ct:Dimension_t" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="IncompatibleMaterials_t">
    <xs:sequence>
