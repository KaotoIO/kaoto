<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logistics Information Schema (Source Param3)
  
  Purpose: Comprehensive logistics and supply chain schema with enterprise complexity
  Demonstrates: Substitution groups for shipment types, carrier methods, warehouse operations,
                xs:extension, xs:restriction, xs:import patterns
  
  This schema represents complex logistics scenarios including multiple shipment types,
  carrier integrations, warehouse management, tracking, and customs documentation.
  Follows enterprise patterns similar to FIXML/FPML/FMM.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:log="http://www.kaoto.io/logistics"
           xmlns:ct="http://www.kaoto.io/common/types"
           xmlns:addr="http://www.kaoto.io/common/address"
           xmlns:party="http://www.kaoto.io/common/party"
           xmlns:fin="http://www.kaoto.io/common/financial"
           xmlns:dt="http://www.kaoto.io/common/datetime"
           targetNamespace="http://www.kaoto.io/logistics"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <!-- ================================================================ -->
  <!-- IMPORTS - Cross-namespace references -->
  <!-- ================================================================ -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common/common-types.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/address"
             schemaLocation="common/common-address.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/party"
             schemaLocation="common/common-party.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/financial"
             schemaLocation="common/common-financial.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/datetime"
             schemaLocation="common/common-datetime.xsd"/>

  <!-- ================================================================ -->
  <!-- DOCUMENTATION -->
  <!-- ================================================================ -->
  <xs:annotation>
    <xs:documentation xml:lang="en">
      Logistics Information Schema for Kaoto DataMapper Enterprise Testing
      
      This schema demonstrates enterprise-level logistics complexity including:
      - 4-level substitution groups for shipment types
      - Complex carrier and routing management
      - Warehouse operations and inventory tracking
      - Customs documentation and compliance
      - Real-time tracking and status updates
      
      Version: 1.0
      Namespace: http://www.kaoto.io/logistics
      
      Total complexity: ~1850 lines
      Demonstrates: Advanced logistics patterns with substitution groups
    </xs:documentation>
  </xs:annotation>

  <!-- ================================================================ -->
  <!-- ROOT ELEMENT -->
  <!-- ================================================================ -->

  <xs:element name="LogisticsInfo" type="log:LogisticsInfo_t">
    <xs:annotation>
      <xs:documentation>
        Root element for logistics information document.
        Contains complete logistics details for shipments and operations.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================ -->
  <!-- LOGISTICS INFO TYPE -->
  <!-- ================================================================ -->

  <xs:complexType name="LogisticsInfo_t">
    <xs:annotation>
      <xs:documentation>
        Main logistics information structure.
        Contains shipments, carriers, warehouses, and tracking details.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LogisticsHeader" type="log:LogisticsHeader_t">
        <xs:annotation>
          <xs:documentation>Logistics header with identification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Shipments" type="log:Shipments_t">
        <xs:annotation>
          <xs:documentation>
            Collection of shipments.
            Demonstrates: Shipment type substitution group (4 levels).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CarrierInformation" type="log:CarrierInformation_t">
        <xs:annotation>
          <xs:documentation>Carrier and transportation details.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="WarehouseOperations" type="log:WarehouseOperations_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Warehouse operations and inventory.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="RoutingInformation" type="log:RoutingInformation_t">
        <xs:annotation>
          <xs:documentation>Routing and transit details.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TrackingInformation" type="log:TrackingInformation_t">
        <xs:annotation>
          <xs:documentation>Real-time tracking information.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CustomsDocumentation" type="log:CustomsDocumentation_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Customs and international shipping documentation.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InsuranceInformation" type="log:InsuranceInformation_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Shipping insurance details.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DeliveryConfirmation" type="log:DeliveryConfirmation_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Delivery confirmation and proof of delivery.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShippingPreferences" type="log:ShippingPreferences_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Customer-facing shipping preferences for carrier, delivery instructions, and scheduling.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Notes" type="ct:Note_t" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Additional logistics notes.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attributeGroup ref="ct:AuditAttributes"/>
    <xs:attribute name="version" type="xs:string" use="required"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- LOGISTICS HEADER -->
  <!-- ================================================================ -->

  <xs:complexType name="LogisticsHeader_t">
    <xs:annotation>
      <xs:documentation>Logistics header with identification and metadata.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LogisticsID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique logistics identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LogisticsNumber" type="ct:ReferenceNumber_t">
        <xs:annotation>
          <xs:documentation>Human-readable logistics number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CreationDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time logistics record was created.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderReference" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Reference to related order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShipmentPriority" type="log:ShipmentPriority_t">
        <xs:annotation>
          <xs:documentation>Overall shipment priority.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LogisticsStatus" type="log:LogisticsStatus_t">
        <xs:annotation>
          <xs:documentation>Current logistics status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ServiceLevel" type="log:ServiceLevel_t">
        <xs:annotation>
          <xs:documentation>Service level agreement.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="EstimatedDeliveryDate" type="xs:dateTime" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Estimated delivery date/time.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ActualDeliveryDate" type="xs:dateTime" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Actual delivery date/time.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- SHIPMENTS COLLECTION -->
  <!-- ================================================================ -->

  <xs:complexType name="Shipments_t">
    <xs:annotation>
      <xs:documentation>Collection of shipments with various types.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="log:Shipment" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Individual shipment (uses substitution group).
            Demonstrates: 4-level shipment type hierarchy.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="totalShipments" type="xs:positiveInteger" use="optional"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- SHIPMENT TYPE SUBSTITUTION GROUP (4 LEVELS) -->
  <!-- ================================================================ -->

  <!-- Level 1: Abstract Base -->
  <xs:element name="Shipment" type="log:Abstract_Shipment_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base for shipment substitution group.
        Level 1 of 4-level substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="Abstract_Shipment_t" abstract="true">
    <xs:annotation>
      <xs:documentation>Abstract base type for all shipments.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ShipmentID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique shipment identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShipmentNumber" type="ct:ReferenceNumber_t">
        <xs:annotation>
          <xs:documentation>Shipment tracking number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShipmentDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time shipment was created.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShipmentStatus" type="log:ShipmentStatus_t">
        <xs:annotation>
          <xs:documentation>Current shipment status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShipFrom" type="log:ShipmentLocation_t">
        <xs:annotation>
          <xs:documentation>Origin location.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ShipTo" type="log:ShipmentLocation_t">
        <xs:annotation>
          <xs:documentation>Destination location.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TotalWeight" type="ct:Weight_t">
        <xs:annotation>
          <xs:documentation>Total shipment weight.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="WeightUnit" type="ct:WeightUnit_t">
        <xs:annotation>
          <xs:documentation>Unit of weight measurement.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Level 2: Standard Shipment -->
  <xs:element name="StandardShipment" substitutionGroup="log:Shipment" type="log:StandardShipment_t">
    <xs:annotation>
      <xs:documentation>
        Standard ground shipment.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="StandardShipment_t">
    <xs:annotation>
      <xs:documentation>Standard shipment with normal delivery.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:Abstract_Shipment_t">
        <xs:sequence>
          <xs:element name="EstimatedTransitDays" type="xs:positiveInteger">
            <xs:annotation>
              <xs:documentation>Estimated transit time in days.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Packages" type="log:Packages_t">
            <xs:annotation>
              <xs:documentation>Packages in shipment.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ShippingCost" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Shipping cost.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SignatureRequired" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Whether signature is required.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Express Shipment (extends StandardShipment) -->
  <xs:element name="ExpressShipment" substitutionGroup="log:StandardShipment" type="log:ExpressShipment_t">
    <xs:annotation>
      <xs:documentation>
        Express shipment with expedited delivery.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ExpressShipment_t">
    <xs:annotation>
      <xs:documentation>Express shipment extending standard shipment.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:StandardShipment_t">
        <xs:sequence>
          <xs:element name="ExpressService" type="log:ExpressService_t">
            <xs:annotation>
              <xs:documentation>Express service level.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="GuaranteedDelivery" type="xs:dateTime">
            <xs:annotation>
              <xs:documentation>Guaranteed delivery date/time.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExpressFee" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Additional express service fee.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PriorityHandling" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Priority handling enabled.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 4: Overnight Shipment (extends ExpressShipment) -->
  <xs:element name="OvernightShipment" substitutionGroup="log:ExpressShipment" type="log:OvernightShipment_t">
    <xs:annotation>
      <xs:documentation>
        Overnight delivery shipment.
        Level 4 of substitution hierarchy (deepest level).
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="OvernightShipment_t">
    <xs:annotation>
      <xs:documentation>Overnight shipment with next-day delivery.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:ExpressShipment_t">
        <xs:sequence>
          <xs:element name="CutoffTime" type="xs:time">
            <xs:annotation>
              <xs:documentation>Cutoff time for overnight processing.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DeliveryWindow" type="dt:TimeWindow_t">
            <xs:annotation>
              <xs:documentation>Delivery time window.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SaturdayDelivery" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Saturday delivery available.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="EarlyAM" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Early AM delivery (before 10:30 AM).</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Freight Shipment (parallel branch) -->
  <xs:element name="FreightShipment" substitutionGroup="log:Shipment" type="log:FreightShipment_t">
    <xs:annotation>
      <xs:documentation>
        Freight shipment for large/heavy items.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="FreightShipment_t">
    <xs:annotation>
      <xs:documentation>Freight shipment for bulk cargo.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:Abstract_Shipment_t">
        <xs:sequence>
          <xs:element name="FreightClass" type="log:FreightClass_t">
            <xs:annotation>
              <xs:documentation>NMFC freight class.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LoadType" type="log:LoadType_t">
            <xs:annotation>
              <xs:documentation>Type of freight load.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Pallets" type="log:Pallets_t">
            <xs:annotation>
              <xs:documentation>Pallet information.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="LiftgateRequired" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Whether liftgate service is required.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="InsideDelivery" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Inside delivery service.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AppointmentRequired" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Delivery appointment required.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: LTL Shipment (extends FreightShipment) -->
  <xs:element name="LTLShipment" substitutionGroup="log:FreightShipment" type="log:LTLShipment_t">
    <xs:annotation>
      <xs:documentation>
        Less-than-truckload shipment.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="LTLShipment_t">
    <xs:annotation>
      <xs:documentation>LTL shipment for partial truckload.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:FreightShipment_t">
        <xs:sequence>
          <xs:element name="LinearFeet" type="xs:decimal">
            <xs:annotation>
              <xs:documentation>Linear feet of trailer space.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="StackableGoods" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Whether goods are stackable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ConsolidationPoint" type="log:ConsolidationPoint_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Consolidation/break-bulk point.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="EstimatedTransitDays" type="xs:positiveInteger">
            <xs:annotation>
              <xs:documentation>Estimated transit days for LTL.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: International Shipment (parallel branch) -->
  <xs:element name="InternationalShipment" substitutionGroup="log:Shipment" type="log:InternationalShipment_t">
    <xs:annotation>
      <xs:documentation>
        International cross-border shipment.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="InternationalShipment_t">
    <xs:annotation>
      <xs:documentation>International shipment with customs.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:Abstract_Shipment_t">
        <xs:sequence>
          <xs:element name="OriginCountry" type="ct:CountryCode_t">
            <xs:annotation>
              <xs:documentation>Country of origin.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DestinationCountry" type="ct:CountryCode_t">
            <xs:annotation>
              <xs:documentation>Destination country.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CustomsValue" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Declared customs value.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="IncoTerms" type="log:IncoTerms_t">
            <xs:annotation>
              <xs:documentation>International commercial terms.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DutiesAndTaxes" type="log:DutiesAndTaxes_t">
            <xs:annotation>
              <xs:documentation>Duties and taxes information.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CommercialInvoice" type="log:CommercialInvoice_t">
            <xs:annotation>
              <xs:documentation>Commercial invoice for customs.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ExportLicense" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Export license number if required.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Air Freight International (extends InternationalShipment) -->
  <xs:element name="AirFreightInternational" substitutionGroup="log:InternationalShipment" type="log:AirFreightInternational_t">
    <xs:annotation>
      <xs:documentation>
        International air freight shipment.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="AirFreightInternational_t">
    <xs:annotation>
      <xs:documentation>Air freight for international shipping.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="log:InternationalShipment_t">
        <xs:sequence>
          <xs:element name="AirWaybillNumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Air waybill (AWB) number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="FlightDetails" type="log:FlightDetails_t">
            <xs:annotation>
              <xs:documentation>Flight routing details.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DangerousGoods" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Contains dangerous goods.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DGDeclaration" type="log:DangerousGoodsDeclaration_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Dangerous goods declaration.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- SHIPMENT LOCATION -->
  <!-- ================================================================ -->

  <xs:complexType name="ShipmentLocation_t">
    <xs:annotation>
      <xs:documentation>Shipment origin or destination location.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="LocationType" type="log:LocationType_t">
        <xs:annotation>
          <xs:documentation>Type of location.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LocationName" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Location name (warehouse, store, etc.).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="LocationCode" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Location code or identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="addr:Address">
        <xs:annotation>
          <xs:documentation>Physical address.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ContactPerson" type="party:Person_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Contact person at location.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ContactPhone" type="ct:PhoneNumber_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Contact phone number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OperatingHours" type="log:OperatingHours_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Operating hours for pickup/delivery.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="SpecialInstructions" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Special instructions for location.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="OperatingHours_t">
    <xs:sequence>
      <xs:element name="DaySchedule" type="log:DaySchedule_t" maxOccurs="7"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="DaySchedule_t">
    <xs:sequence>
      <xs:element name="DayOfWeek" type="xs:string"/>
      <xs:element name="OpenTime" type="xs:time"/>
      <xs:element name="CloseTime" type="xs:time"/>
      <xs:element name="Closed" type="xs:boolean" default="false"/>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- PACKAGES -->
  <!-- ================================================================ -->

  <xs:complexType name="Packages_t">
    <xs:sequence>
      <xs:element name="Package" type="log:Package_t" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="Package_t">
    <xs:annotation>
      <xs:documentation>Individual package with 20+ fields.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="PackageID" type="ct:UUID_t"/>
      <xs:element name="PackageNumber" type="xs:string"/>
