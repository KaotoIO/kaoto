<?xml version="1.0" encoding="UTF-8"?>
<!--
  Billing Information Schema (Source Param1)
  
  Purpose: Comprehensive billing and invoicing schema with enterprise complexity
  Demonstrates: Substitution groups for billing methods, abstract invoice types,
                xs:extension, xs:restriction, xs:import patterns
  
  This schema represents complex billing scenarios including multiple invoice types,
  payment schedules, credit management, and tax calculations.
  Follows enterprise patterns similar to FIXML/FPML/FMM.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:bill="http://www.kaoto.io/billing"
           xmlns:ct="http://www.kaoto.io/common/types"
           xmlns:addr="http://www.kaoto.io/common/address"
           xmlns:party="http://www.kaoto.io/common/party"
           xmlns:fin="http://www.kaoto.io/common/financial"
           xmlns:dt="http://www.kaoto.io/common/datetime"
           targetNamespace="http://www.kaoto.io/billing"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

  <!-- ================================================================ -->
  <!-- IMPORTS - Cross-namespace references -->
  <!-- ================================================================ -->
  <xs:import namespace="http://www.kaoto.io/common/types"
             schemaLocation="common/common-types.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/address"
             schemaLocation="common/common-address.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/party"
             schemaLocation="common/common-party.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/financial"
             schemaLocation="common/common-financial.xsd"/>
  <xs:import namespace="http://www.kaoto.io/common/datetime"
             schemaLocation="common/common-datetime.xsd"/>

  <!-- ================================================================ -->
  <!-- DOCUMENTATION -->
  <!-- ================================================================ -->
  <xs:annotation>
    <xs:documentation xml:lang="en">
      Billing Information Schema for Kaoto DataMapper Enterprise Testing
      
      This schema demonstrates enterprise-level billing complexity including:
      - 4-level substitution groups for invoice types
      - Abstract billing methods with concrete implementations
      - Complex payment schedules and credit management
      - Multi-currency billing support
      - Tax calculation frameworks
      
      Version: 1.0
      Namespace: http://www.kaoto.io/billing
      
      Total complexity: ~1650 lines
      Demonstrates: Advanced billing patterns with substitution groups
    </xs:documentation>
  </xs:annotation>

  <!-- ================================================================ -->
  <!-- ROOT ELEMENT -->
  <!-- ================================================================ -->

  <xs:element name="BillingInfo" type="bill:BillingInfo_t">
    <xs:annotation>
      <xs:documentation>
        Root element for billing information document.
        Contains complete billing details for an order or account.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <!-- ================================================================ -->
  <!-- BILLING INFO TYPE -->
  <!-- ================================================================ -->

  <xs:complexType name="BillingInfo_t">
    <xs:annotation>
      <xs:documentation>
        Main billing information structure.
        Contains billing account, invoices, payments, and credit details.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="BillingHeader" type="bill:BillingHeader_t">
        <xs:annotation>
          <xs:documentation>Billing header with identification.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingAccount" type="bill:BillingAccount_t">
        <xs:annotation>
          <xs:documentation>Billing account information.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillToParty" type="party:Organization_t">
        <xs:annotation>
          <xs:documentation>Party to be billed.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element ref="addr:Address">
        <xs:annotation>
          <xs:documentation>Billing address (uses substitution group).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Invoices" type="bill:Invoices_t">
        <xs:annotation>
          <xs:documentation>
            Collection of invoices.
            Demonstrates: Invoice type substitution group (4 levels).
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PaymentSchedule" type="bill:PaymentSchedule_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Payment schedule for installments.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CreditManagement" type="bill:CreditManagement_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Credit management and limits.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PaymentHistory" type="bill:PaymentHistory_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Historical payment records.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingPreferences" type="bill:BillingPreferences_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Customer billing preferences.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TaxConfiguration" type="bill:TaxConfiguration_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Tax configuration for billing.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Notes" type="ct:Note_t" minOccurs="0" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Additional billing notes.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
    <xs:attributeGroup ref="ct:AuditAttributes"/>
    <xs:attribute name="version" type="xs:string" use="required"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- BILLING HEADER -->
  <!-- ================================================================ -->

  <xs:complexType name="BillingHeader_t">
    <xs:annotation>
      <xs:documentation>Billing header with identification and metadata.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="BillingID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique billing identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingNumber" type="ct:ReferenceNumber_t">
        <xs:annotation>
          <xs:documentation>Human-readable billing number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Date/time billing was created.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingPeriod" type="bill:BillingPeriod_t">
        <xs:annotation>
          <xs:documentation>Billing period covered.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Currency" type="ct:CurrencyCode_t">
        <xs:annotation>
          <xs:documentation>Primary currency for billing.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingStatus" type="bill:BillingStatus_t">
        <xs:annotation>
          <xs:documentation>Current billing status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OrderReference" type="ct:UUID_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reference to related order.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ContractReference" type="ct:ReferenceNumber_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Reference to billing contract.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="FiscalYear" type="xs:gYear">
        <xs:annotation>
          <xs:documentation>Fiscal year for accounting.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="FiscalPeriod" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>Fiscal period within year.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="BillingPeriod_t">
    <xs:annotation>
      <xs:documentation>Billing period specification.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="StartDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Period start date.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="EndDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Period end date.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PeriodType" type="bill:PeriodType_t">
        <xs:annotation>
          <xs:documentation>Type of billing period.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- BILLING ACCOUNT -->
  <!-- ================================================================ -->

  <xs:complexType name="BillingAccount_t">
    <xs:annotation>
      <xs:documentation>
        Billing account with 20+ fields for complete account management.
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="AccountID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique account identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountNumber" type="xs:string">
        <xs:annotation>
          <xs:documentation>Account number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountName" type="xs:string">
        <xs:annotation>
          <xs:documentation>Account name.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountType" type="bill:AccountType_t">
        <xs:annotation>
          <xs:documentation>Type of billing account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountStatus" type="bill:AccountStatus_t">
        <xs:annotation>
          <xs:documentation>Current account status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="OpenDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Date account was opened.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CloseDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Date account was closed (if applicable).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CreditLimit" type="ct:MonetaryAmount_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Credit limit for account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="CurrentBalance" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>Current account balance.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AvailableCredit" type="ct:MonetaryAmount_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Available credit remaining.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PaymentTerms" type="fin:PaymentTerms_t">
        <xs:annotation>
          <xs:documentation>Default payment terms for account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="BillingCycle" type="bill:BillingCycle_t">
        <xs:annotation>
          <xs:documentation>Billing cycle for account.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="StatementDay" type="xs:positiveInteger" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Day of month for statement generation (1-31).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DueDay" type="xs:positiveInteger" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Day of month payment is due (1-31).</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AutoPay" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>Whether auto-pay is enabled.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="PaperlessStatements" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>Whether paperless statements are enabled.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="AccountManager" type="party:Person_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Assigned account manager.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TaxExempt" type="xs:boolean" default="false">
        <xs:annotation>
          <xs:documentation>Whether account is tax exempt.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TaxExemptionCertificate" type="xs:string" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Tax exemption certificate number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ParentAccountID" type="ct:UUID_t" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Parent account ID for sub-accounts.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attributeGroup ref="ct:CommonAttributes"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- INVOICES COLLECTION -->
  <!-- ================================================================ -->

  <xs:complexType name="Invoices_t">
    <xs:annotation>
      <xs:documentation>Collection of invoices with various types.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="bill:Invoice" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Individual invoice (uses substitution group).
            Demonstrates: 4-level invoice type hierarchy.
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
    <xs:attribute name="totalInvoices" type="xs:positiveInteger" use="optional"/>
  </xs:complexType>

  <!-- ================================================================ -->
  <!-- INVOICE TYPE SUBSTITUTION GROUP (4 LEVELS) -->
  <!-- ================================================================ -->

  <!-- Level 1: Abstract Base -->
  <xs:element name="Invoice" type="bill:Abstract_Invoice_t" abstract="true">
    <xs:annotation>
      <xs:documentation>
        Abstract base for invoice substitution group.
        Level 1 of 4-level substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="Abstract_Invoice_t" abstract="true">
    <xs:annotation>
      <xs:documentation>Abstract base type for all invoices.</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="InvoiceID" type="ct:UUID_t">
        <xs:annotation>
          <xs:documentation>Unique invoice identifier.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InvoiceNumber" type="ct:ReferenceNumber_t">
        <xs:annotation>
          <xs:documentation>Invoice number.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InvoiceDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Invoice date.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="DueDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Payment due date.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="InvoiceStatus" type="bill:InvoiceStatus_t">
        <xs:annotation>
          <xs:documentation>Current invoice status.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="Currency" type="ct:CurrencyCode_t">
        <xs:annotation>
          <xs:documentation>Invoice currency.</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="TotalAmount" type="ct:MonetaryAmount_t">
        <xs:annotation>
          <xs:documentation>Total invoice amount.</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <!-- Level 2: Standard Invoice -->
  <xs:element name="StandardInvoice" substitutionGroup="bill:Invoice" type="bill:StandardInvoice_t">
    <xs:annotation>
      <xs:documentation>
        Standard invoice type.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="StandardInvoice_t">
    <xs:annotation>
      <xs:documentation>Standard invoice with line items.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="bill:Abstract_Invoice_t">
        <xs:sequence>
          <xs:element name="LineItems" type="bill:InvoiceLineItems_t">
            <xs:annotation>
              <xs:documentation>Invoice line items.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Subtotal" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Subtotal before tax.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TaxDetails" type="fin:TaxDetails_t">
            <xs:annotation>
              <xs:documentation>Tax calculation details.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="PaymentInstructions" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Payment instructions.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Recurring Invoice (extends StandardInvoice) -->
  <xs:element name="RecurringInvoice" substitutionGroup="bill:StandardInvoice" type="bill:RecurringInvoice_t">
    <xs:annotation>
      <xs:documentation>
        Recurring invoice for subscriptions.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="RecurringInvoice_t">
    <xs:annotation>
      <xs:documentation>Recurring invoice extending standard invoice.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="bill:StandardInvoice_t">
        <xs:sequence>
          <xs:element name="RecurrenceSchedule" type="dt:Schedule_t">
            <xs:annotation>
              <xs:documentation>Recurrence schedule.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="SubscriptionID" type="ct:UUID_t">
            <xs:annotation>
              <xs:documentation>Related subscription identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="BillingCycleNumber" type="xs:positiveInteger">
            <xs:annotation>
              <xs:documentation>Current billing cycle number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="NextBillingDate" type="xs:date">
            <xs:annotation>
              <xs:documentation>Next scheduled billing date.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AutoRenew" type="xs:boolean" default="true">
            <xs:annotation>
              <xs:documentation>Whether subscription auto-renews.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 4: Subscription Invoice (extends RecurringInvoice) -->
  <xs:element name="SubscriptionInvoice" substitutionGroup="bill:RecurringInvoice" type="bill:SubscriptionInvoice_t">
    <xs:annotation>
      <xs:documentation>
        Subscription-based invoice with usage tracking.
        Level 4 of substitution hierarchy (deepest level).
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="SubscriptionInvoice_t">
    <xs:annotation>
      <xs:documentation>Subscription invoice with usage details.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="bill:RecurringInvoice_t">
        <xs:sequence>
          <xs:element name="UsageDetails" type="bill:UsageDetails_t">
            <xs:annotation>
              <xs:documentation>Usage-based billing details.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="TierLevel" type="xs:string" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Subscription tier level.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="Overages" type="bill:Overages_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Usage overages beyond plan limits.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ProrationDetails" type="bill:ProrationDetails_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Proration details for partial periods.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Credit Memo (parallel branch) -->
  <xs:element name="CreditMemo" substitutionGroup="bill:Invoice" type="bill:CreditMemo_t">
    <xs:annotation>
      <xs:documentation>
        Credit memo for returns/adjustments.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="CreditMemo_t">
    <xs:annotation>
      <xs:documentation>Credit memo reducing amount owed.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="bill:Abstract_Invoice_t">
        <xs:sequence>
          <xs:element name="OriginalInvoiceID" type="ct:UUID_t">
            <xs:annotation>
              <xs:documentation>Reference to original invoice.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CreditReason" type="bill:CreditReason_t">
            <xs:annotation>
              <xs:documentation>Reason for credit.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CreditAmount" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Credit amount.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="CreditLineItems" type="bill:CreditLineItems_t">
            <xs:annotation>
              <xs:documentation>Line items being credited.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="AppliedToInvoice" type="xs:boolean" default="false">
            <xs:annotation>
              <xs:documentation>Whether credit has been applied.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Return Credit Memo (extends CreditMemo) -->
  <xs:element name="ReturnCreditMemo" substitutionGroup="bill:CreditMemo" type="bill:ReturnCreditMemo_t">
    <xs:annotation>
      <xs:documentation>
        Credit memo for product returns.
        Level 3 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="ReturnCreditMemo_t">
    <xs:annotation>
      <xs:documentation>Credit memo for returned products.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="bill:CreditMemo_t">
        <xs:sequence>
          <xs:element name="ReturnAuthorizationNumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>RMA number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="ReturnDate" type="xs:date">
            <xs:annotation>
              <xs:documentation>Date items were returned.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RestockingFee" type="ct:MonetaryAmount_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Restocking fee if applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="RefundMethod" type="bill:RefundMethod_t">
            <xs:annotation>
              <xs:documentation>Method of refund.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 2: Debit Memo (parallel branch) -->
  <xs:element name="DebitMemo" substitutionGroup="bill:Invoice" type="bill:DebitMemo_t">
    <xs:annotation>
      <xs:documentation>
        Debit memo for additional charges.
        Level 2 of substitution hierarchy.
      </xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:complexType name="DebitMemo_t">
    <xs:annotation>
      <xs:documentation>Debit memo increasing amount owed.</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="bill:Abstract_Invoice_t">
        <xs:sequence>
          <xs:element name="OriginalInvoiceID" type="ct:UUID_t" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Reference to original invoice if applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DebitReason" type="bill:DebitReason_t">
            <xs:annotation>
              <xs:documentation>Reason for debit.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DebitAmount" type="ct:MonetaryAmount_t">
            <xs:annotation>
              <xs:documentation>Additional amount charged.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="DebitLineItems" type="bill:DebitLineItems_t">
            <xs:annotation>
              <xs:documentation>Line items for additional charges.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <!-- Level 3: Late Fee Debit (extends DebitMemo) -->
  <xs:element name="LateFeeDebit" substitutionGroup="bill:DebitMemo" type="bill:LateFeeDebit_t">
    <xs:annotation>
      <xs:documentation>
        Debit memo for late payment fees.
        Level 3 of substitution hierarchy.
      </xs:documentation>
